# GIOS Environment Variables
# cp .env.example .env.local して値を設定してください

NOTION_API_KEY=secret_xxx

# Score Engine Sync Layer — DB ごとの ID を個別に設定
NOTION_DATABASE_ID_CUSTOMER=xxx
NOTION_DATABASE_ID_POWERMEETING=xxx
NOTION_DATABASE_ID_VOICE=xxx
NOTION_DATABASE_ID_STORY=xxx
NOTION_DATABASE_ID_PAIN=xxx
NOTION_DATABASE_ID_GROWTH=xxx
NOTION_DATABASE_ID_NEXTACTION=xxx
NOTION_DATABASE_ID_AIAGENT=xxx
NOTION_DATABASE_ID_SYNC_ALERTS=xxx

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# クライアントサイド (NEXT_PUBLIC_ 必須)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

ANTHROPIC_API_KEY=sk-ant-xxx

NEXT_PUBLIC_APP_URL=http://localhost:3000
